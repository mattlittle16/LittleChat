# ── OIDC / Auth ──────────────────────────────────────────────────────────────
# Any OIDC-compliant IdP works (Keycloak, Auth0, Okta, Authelia, Authentik...)
# Point OIDC_AUTHORITY at your IdP's issuer URL.
OIDC_AUTHORITY=https://your-idp.example.com/application/o/littlechat/
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
# Set to true only if your IdP uses hybrid flow (Authentik users: set this to true)
OIDC_SKIP_RESPONSE_VALIDATION=false

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=localdevpassword
POSTGRES_DB=littlechat
# Full connection string (built from above in docker-compose; set directly in prod)
# POSTGRES_CONNECTION_STRING=Host=chat-db;Database=littlechat;Username=postgres;Password=localdevpassword

# ── Valkey (Redis-compatible) ────────────────────────────────────────────────
VALKEY_CONNECTION_STRING=valkey:6379

# ── File Uploads ─────────────────────────────────────────────────────────────
# Absolute path on the host where uploaded files are stored
UPLOAD_PATH=/tmp/littlechat-uploads

# ── Messaging ────────────────────────────────────────────────────────────────
# Number of messages loaded per history page (operator-configurable)
MESSAGE_PAGE_SIZE=100

# ── CORS ─────────────────────────────────────────────────────────────────────
# Allowed CORS origin for the backend API (also used as the OIDC redirect base URL)
CORS_ORIGIN=http://localhost:3000

# ── Admin Panel ───────────────────────────────────────────────────────────────
# The JWT claim field used to identify admin users (default: groups)
ADMIN_CLAIM_FIELD=groups
# Comma-separated list of claim values that grant admin access (default: app-admin)
ADMIN_CLAIM_VALUES=app-admin

# ── Optional ─────────────────────────────────────────────────────────────────
KLIPY_API_KEY=

    <ProjectReference Include="..\..\src\Modules\Presence\API\Presence.API.csproj" />
    <ProjectReference Include="..\..\src\Modules\Reactions\API\Reactions.API.csproj" />
    <ProjectReference Include="..\..\src\Modules\Search\API\Search.API.csproj" />
    <ProjectReference Include="..\..\src\Modules\Files\API\Files.API.csproj" />
    <ProjectReference Include="..\..\src\Modules\Notifications\API\Notifications.API.csproj" />
    <ProjectReference Include="..\..\src\Modules\RealTime\API\RealTime.API.csproj" />
    <ProjectReference Include="..\..\src\Modules\Admin\API\Admin.API.csproj" />


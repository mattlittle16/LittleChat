# Admin Panel — mirrors the backend ADMIN_CLAIM_FIELD / ADMIN_CLAIM_VALUES settings.
# Used client-side to show/hide the admin nav link and gate the /admin route.
# Server-side enforcement is authoritative; these values are UX-only.

# The JWT claim field used to identify admin users (default: groups)
VITE_ADMIN_CLAIM_FIELD=groups

# Comma-separated list of claim values that grant admin access (default: app-admin)
VITE_ADMIN_CLAIM_VALUES=app-admin
